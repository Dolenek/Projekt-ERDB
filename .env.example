# EpicRPGBotCSharp environment configuration
# Copy this file to `.env` and fill the values as needed.

BASE_URL=https://discord.com
DISCORD_CHANNEL_URL=http://discord.com/channels/0000000000000000000/0000000000000000000
AREA=10
DISCORD_EMAIL=
DISCORD_PASSWORD=
#Found in chrome://version
SOURCE_USER_DATA_DIR="C:\Users\YOUR_USER\AppData\Local\Google\Chrome\User Data"
PROFILE_NAME="Profile 1"

# Captcha solver
CAPTCHA_OPENAI_API_KEY=
CAPTCHA_OPENAI_MODEL=gpt-5-mini
CAPTCHA_OPENAI_RETRY_MODEL=gpt-5
CAPTCHA_ITEM_NAMES_FILE=items.json
CAPTCHA_API_TIMEOUT_SECONDS=10
CAPTCHA_SELFTEST=0
CAPTCHA_SELFTEST_REPLAY_DIR=
