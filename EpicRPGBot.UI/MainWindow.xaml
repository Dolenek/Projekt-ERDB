<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="EpicRPGBot.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="EpicRPG Bot UI" Height="800" Width="1300" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CooldownRowBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
        </Style>
        <Style x:Key="BrowserTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="#2b2d31"/>
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="BorderBrush" Value="#3a3c42"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="LightBlue"/>
                                <Setter Property="Foreground" Value="#10243a"/>
                                <Setter Property="Panel.ZIndex" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#7fb8e6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#1e1f22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#242529" BorderBrush="#2f3136" BorderThickness="0,0,1,0">
            <DockPanel Margin="12">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Button Name="LastMessagesTabBtn" Content="Last messages" Margin="0,0,8,0" Padding="8,4" Click="LastMessagesTabBtn_Click"/>
                    <Button Name="StatsTabBtn" Content="Stats" Margin="0,0,8,0" Padding="8,4" Click="StatsTabBtn_Click"/>
                    <Button Name="ConsoleTabBtn" Content="Console" Padding="8,4" Click="ConsoleTabBtn_Click"/>
                </StackPanel>

                <Grid>
                    <Grid Name="LastMessagesPanel" Visibility="Visible">
                        <ListBox Name="StatsList"
                                 Background="#1e1f22"
                                 Foreground="#ddd"
                                 BorderBrush="#3a3c42"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=., Mode=OneWay}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Grid Name="StatsPanel" Visibility="Collapsed">
                        <StackPanel Background="#1e1f22" Margin="4">
                            <TextBlock Text="Stats" Foreground="#ddd" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Name="HuntCountText" Text="Hunt sent: 0" Foreground="#ddd"/>
                            <TextBlock Name="AdventureCountText" Text="Adventure sent: 0" Foreground="#ddd" Margin="0,4,0,0"/>
                            <TextBlock Name="TrainingCountText" Text="Training sent: 0" Foreground="#ddd" Margin="0,4,0,0"/>
                            <TextBlock Name="WorkCountText" Text="Work sent: 0" Foreground="#ddd" Margin="0,4,0,0"/>
                            <TextBlock Name="FarmCountText" Text="Farm sent: 0" Foreground="#ddd" Margin="0,4,0,0"/>
                            <TextBlock Name="LootboxCountText" Text="Lootbox sent: 0" Foreground="#ddd" Margin="0,4,0,0"/>
                            <TextBlock Name="RunningCooldownsText" Text="Running cooldowns: 0 / 15" Foreground="#ddd" Margin="0,4,0,0"/>
                            <TextBlock Name="RunningRewardsText" Text="Rewards running: 0 / 5" Foreground="#ddd" Margin="0,4,0,0"/>
                            <TextBlock Name="RunningExperienceText" Text="Experience running: 0 / 5" Foreground="#ddd" Margin="0,4,0,0"/>
                            <TextBlock Name="RunningProgressText" Text="Progress running: 0 / 5" Foreground="#ddd" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Name="ConsolePanel" Visibility="Collapsed">
                        <ListBox Name="ConsoleList"
                                 Background="#1e1f22"
                                 Foreground="#ddd"
                                 BorderBrush="#3a3c42"
                                 HorizontalContentAlignment="Stretch"
                                 SelectionMode="Extended"
                                 PreviewKeyDown="ConsoleList_PreviewKeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=., Mode=OneWay}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Background="#2b2d31" LastChildFill="False">
                <TextBlock Text="Discord" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#ddd" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <Button Name="DismantleBtn" Content="Dismantle" Margin="8,6" Padding="12,4" Click="DismantleBtn_Click"/>
                    <Button Name="CraftingBtn" Content="Crafting" Margin="8,6" Padding="12,4" Click="CraftingBtn_Click"/>
                    <Button Name="SettingsBtn" Content="Settings" Margin="8,6" Padding="12,4" Click="SettingsBtn_Click"/>
                    <Button Name="ReloadBtn" Content="Reload" Margin="8,6" Padding="12,4" Click="ReloadBtn_Click"/>
                    <Button Name="GoChannelBtn" Content="Go To Channel" Margin="8,6" Padding="12,4" Click="GoChannelBtn_Click"/>
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Background="#1e1f22">
                <TabControl Name="BrowserTabs"
                            Background="#1e1f22"
                            BorderBrush="#2f3136"
                            Foreground="#ddd"
                            SelectedIndex="0">
                    <TabItem Name="PlayerBrowserTab" Header="Player tab" Style="{StaticResource BrowserTabItemStyle}">
                        <Grid Background="#1e1f22">
                            <wv2:WebView2 Name="PlayerWeb" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Grid>
                    </TabItem>
                    <TabItem Name="BotBrowserTab" Header="Bot tab" Style="{StaticResource BrowserTabItemStyle}">
                        <Grid Background="#1e1f22">
                            <wv2:WebView2 Name="Web" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Grid>
                    </TabItem>
                    <TabItem Name="GuildBrowserTab" Header="Guild tab" Style="{StaticResource BrowserTabItemStyle}">
                        <Grid Background="#1e1f22">
                            <wv2:WebView2 Name="GuildWeb" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Grid>
                    </TabItem>
                    <TabItem Name="DungeonBrowserTab" Header="Dungeon tab" Style="{StaticResource BrowserTabItemStyle}">
                        <Grid Background="#1e1f22">
                            <wv2:WebView2 Name="DungeonWeb" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Grid>
                    </TabItem>
                </TabControl>
                <TextBlock Name="InitHint" Text="Loading WebView2..." Foreground="#bbb" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
            </Grid>
        </Grid>
        <Border Grid.Column="2" Background="#242529" BorderBrush="#2f3136" BorderThickness="1,0,0,0">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Bot Controls" Foreground="#ddd" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Name="StartBtn" Grid.Row="0" Grid.Column="0" Content="Start Bot" Margin="0,0,8,8" MinHeight="30" Padding="12,4" Click="StartBtn_Click"/>
                        <Button Name="StopBtn" Grid.Row="0" Grid.Column="1" Content="Stop Bot" Margin="0,0,8,8" MinHeight="30" Padding="12,4" Click="StopBtn_Click"/>
                        <Button Name="InitBtn" Grid.Row="0" Grid.Column="2" Content="Inicialize" Margin="0,0,0,8" MinHeight="30" Padding="12,4" Click="InitBtn_Click"/>
                        <Button Name="RpgCdBtn" Grid.Row="1" Grid.Column="0" Content="rpg cd" Margin="0,0,8,0" MinHeight="30" Padding="12,4" Click="RpgCdBtn_Click"/>
                        <Button Name="TradeAreaBtn" Grid.Row="1" Grid.Column="1" Content="Trade area" Margin="0,0,8,0" MinHeight="30" Padding="12,4" Click="TradeAreaBtn_Click"/>
                        <Button Name="WishingTokenBtn" Grid.Row="1" Grid.Column="2" Content="Wishing token" Margin="0,0,0,0" MinHeight="30" Padding="12,4" Click="WishingTokenBtn_Click"/>
                        <Button Name="CompleteDungeonBtn" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Content="Complete Dungeon" Margin="0,8,0,0" MinHeight="30" Padding="12,4" Click="CompleteDungeonBtn_Click"/>
                    </Grid>

                    <TextBlock Text="Time cookie" Foreground="#ddd" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Name="TimeCookieDungeonBtn" Grid.Column="0" Content="Dungeon" Margin="0,0,8,0" MinHeight="30" Padding="12,4" Click="TimeCookieDungeonBtn_Click"/>
                        <Button Name="TimeCookieDuelBtn" Grid.Column="1" Content="Duel" Margin="0,0,8,0" MinHeight="30" Padding="12,4" Click="TimeCookieDuelBtn_Click"/>
                        <Button Name="TimeCookieCardHandBtn" Grid.Column="2" Content="Card hand" Margin="0,0,0,0" MinHeight="30" Padding="12,4" Click="TimeCookieCardHandBtn_Click"/>
                    </Grid>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,12,0,0"
                              VerticalAlignment="Bottom"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Separator Background="#2f3136" Margin="0,0,0,8"/>
                        <TextBlock Text="Cooldowns (visual)" Foreground="#ddd" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <StackPanel Name="CooldownsPanel" Margin="0,0,0,8">

                        <!-- Rewards -->
                        <TextBlock Text="Rewards" Foreground="#ccc" Margin="0,6,0,2"/>

                        <Border Name="DailyCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="daily" Foreground="#ddd"/>
                                <TextBlock Name="DailyCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="WeeklyCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="weekly" Foreground="#ddd"/>
                                <TextBlock Name="WeeklyCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="LootboxCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="lootbox" Foreground="#ddd"/>
                                <TextBlock Name="LootboxCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="CardHandCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="card hand" Foreground="#ddd"/>
                                <TextBlock Name="CardHandCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="VoteCdRow" Style="{StaticResource CooldownRowBorderStyle}" Margin="0,1,0,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="vote" Foreground="#ddd"/>
                                <TextBlock Name="VoteCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Experience -->
                        <TextBlock Text="Experience" Foreground="#ccc" Margin="0,6,0,2"/>

                        <Border Name="HuntCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="hunt" Foreground="#ddd"/>
                                <TextBlock Name="HuntCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="AdventureCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="adventure" Foreground="#ddd"/>
                                <TextBlock Name="AdventureCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="TrainingCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="training" Foreground="#ddd"/>
                                <TextBlock Name="TrainingCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="DuelCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="duel" Foreground="#ddd"/>
                                <TextBlock Name="DuelCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="QuestCdRow" Style="{StaticResource CooldownRowBorderStyle}" Margin="0,1,0,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="quest | epic quest" Foreground="#ddd"/>
                                <TextBlock Name="QuestCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Progress -->
                        <TextBlock Text="Progress" Foreground="#ccc" Margin="0,6,0,2"/>

                        <Border Name="WorkCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="chop | fish | pickup | mine" Foreground="#ddd"/>
                                <TextBlock Name="WorkCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="FarmCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="farm" Foreground="#ddd"/>
                                <TextBlock Name="FarmCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="HorseCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="horse breeding | horse race" Foreground="#ddd"/>
                                <TextBlock Name="HorseCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="ArenaCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="arena" Foreground="#ddd"/>
                                <TextBlock Name="ArenaCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border Name="DungeonCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="dungeon | miniboss" Foreground="#ddd"/>
                                <TextBlock Name="DungeonCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
