<Window x:Class="EpicRPGBot.UI.Settings.GuildRaidSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Guild raid settings"
        Width="430"
        Height="380"
        MinWidth="430"
        MinHeight="380"
        Background="#1e1f22"
        Foreground="#ddd"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Guild raid" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="Changes save automatically." Foreground="#aaa" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#242529" BorderBrush="#2f3136" BorderThickness="1" CornerRadius="6" Padding="12">
            <StackPanel>
                <TextBlock Text="Channel URL" Foreground="#aaa"/>
                <TextBox Name="GuildRaidChannelUrlBox"
                         Margin="0,4,0,0"
                         Background="#1e1f22"
                         Foreground="#ddd"
                         BorderBrush="#3a3c42"/>

                <TextBlock Text="Trigger text" Foreground="#aaa" Margin="0,12,0,0"/>
                <TextBox Name="GuildRaidTriggerTextBox"
                         Margin="0,4,0,0"
                         Background="#1e1f22"
                         Foreground="#ddd"
                         BorderBrush="#3a3c42"/>

                <TextBlock Text="Match mode" Foreground="#aaa" Margin="0,12,0,0"/>
                <ComboBox Name="GuildRaidMatchModeBox"
                          Margin="0,4,0,0"
                          Background="#1e1f22"
                          Foreground="#ddd"
                          BorderBrush="#3a3c42">
                    <ComboBoxItem Tag="contains" Content="Contains configured text"/>
                    <ComboBoxItem Tag="exact" Content="Exact message match"/>
                </ComboBox>

                <TextBlock Text="Author filter (optional)" Foreground="#aaa" Margin="0,12,0,0"/>
                <TextBox Name="GuildRaidAuthorFilterBox"
                         Margin="0,4,0,0"
                         Background="#1e1f22"
                         Foreground="#ddd"
                         BorderBrush="#3a3c42"/>
            </StackPanel>
        </Border>

        <Button Grid.Row="2"
                Name="CloseBtn"
                Content="Close"
                Width="88"
                Height="30"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Click="CloseBtn_Click"/>
    </Grid>
</Window>
