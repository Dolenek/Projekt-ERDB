<UserControl x:Class="EpicRPGBot.UI.Controls.CooldownPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="280">
    <UserControl.Resources>
        <Style x:Key="CooldownRowBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalAlignment="Bottom" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Separator Background="#2f3136" Margin="0,0,0,8"/>
            <TextBlock Text="Cooldowns (visual)" Foreground="#ddd" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <StackPanel x:Name="CooldownsPanel" Margin="0,0,0,8">
                <TextBlock Text="Rewards" Foreground="#ccc" Margin="0,6,0,2"/>

                <Border x:Name="DailyCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="daily" Foreground="#ddd"/>
                        <TextBlock x:Name="DailyCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="WeeklyCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="weekly" Foreground="#ddd"/>
                        <TextBlock x:Name="WeeklyCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="LootboxCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="lootbox" Foreground="#ddd"/>
                        <TextBlock x:Name="LootboxCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="CardHandCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="card hand" Foreground="#ddd"/>
                        <TextBlock x:Name="CardHandCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="VoteCdRow" Style="{StaticResource CooldownRowBorderStyle}" Margin="0,1,0,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="vote" Foreground="#ddd"/>
                        <TextBlock x:Name="VoteCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <TextBlock Text="Experience" Foreground="#ccc" Margin="0,6,0,2"/>

                <Border x:Name="HuntCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="hunt" Foreground="#ddd"/>
                        <TextBlock x:Name="HuntCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="AdventureCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="adventure" Foreground="#ddd"/>
                        <TextBlock x:Name="AdventureCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="TrainingCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="training" Foreground="#ddd"/>
                        <TextBlock x:Name="TrainingCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="DuelCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="duel" Foreground="#ddd"/>
                        <TextBlock x:Name="DuelCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="QuestCdRow" Style="{StaticResource CooldownRowBorderStyle}" Margin="0,1,0,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="quest | epic quest" Foreground="#ddd"/>
                        <TextBlock x:Name="QuestCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <TextBlock Text="Progress" Foreground="#ccc" Margin="0,6,0,2"/>

                <Border x:Name="WorkCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="chop | fish | pickup | mine" Foreground="#ddd"/>
                        <TextBlock x:Name="WorkCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="FarmCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="farm" Foreground="#ddd"/>
                        <TextBlock x:Name="FarmCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="HorseCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="horse breeding | horse race" Foreground="#ddd"/>
                        <TextBlock x:Name="HorseCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="ArenaCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="arena" Foreground="#ddd"/>
                        <TextBlock x:Name="ArenaCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border x:Name="DungeonCdRow" Style="{StaticResource CooldownRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="dungeon | miniboss" Foreground="#ddd"/>
                        <TextBlock x:Name="DungeonCdText" Grid.Column="1" Text="00h 00m 00s" Foreground="#aaa" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
